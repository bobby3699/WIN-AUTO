{
  "name": "win-auto-ts",
  "version": "1.0.0",
  "description": "TypeScript library for Windows UI Automation via direct COM/UIA FFI using Koffi — no native compilation required",
  "main": "./dist/winauto.js",
  "types": "./dist/winauto.d.ts",
  "exports": {
    ".": {
      "import": "./dist/winauto.js",
      "types": "./dist/winauto.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test tests/test_uia.ts",
    "test:wh": "npx tsx tests/test_wh_app.ts"
  },
  "keywords": [
    "windows",
    "automation",
    "ui-automation",
    "uia",
    "com",
    "ffi",
    "koffi",
    "desktop-automation",
    "accessibility",
    "vtable"
  ],
  "author": "Babul Reddy Korimella <babulreddy.korimella@staedean.com>",
  "license": "ISC",
  "os": ["win32"],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "dependencies": {
    "koffi": "^2.15.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
